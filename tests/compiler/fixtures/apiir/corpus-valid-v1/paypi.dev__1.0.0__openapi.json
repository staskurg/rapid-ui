{
  "api": {
    "title": "EmailVerify",
    "version": "1.0.0"
  },
  "resources": [
    {
      "name": "Checkcode",
      "key": "checkcode",
      "operations": [
        {
          "id": "POST:/checkCode",
          "method": "POST",
          "kind": "create",
          "path": "/checkCode",
          "requestSchema": {
            "properties": {
              "code": {
                "default": 123456,
                "type": "string"
              },
              "email": {
                "default": "test@test.com",
                "type": "string"
              }
            },
            "type": "object"
          },
          "responseSchema": {
            "properties": {
              "message": {
                "type": "string"
              },
              "success": {
                "type": "boolean"
              }
            },
            "type": "object"
          }
        }
      ]
    },
    {
      "name": "Sendcode",
      "key": "sendcode",
      "operations": [
        {
          "id": "POST:/sendCode",
          "method": "POST",
          "kind": "create",
          "path": "/sendCode",
          "requestSchema": {
            "properties": {
              "email": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "responseSchema": {
            "properties": {
              "message": {
                "default": "Verification email sent",
                "type": "boolean"
              },
              "success": {
                "default": true,
                "type": "boolean"
              }
            },
            "type": "object"
          }
        }
      ]
    }
  ]
}